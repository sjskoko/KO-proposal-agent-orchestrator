# Copy to .env and fill in values

# --- Local Model ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:27b

# --- API Keys (optional — only needed if using API fallbacks) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- MCP Servers ---
BRAVE_API_KEY=           # for mcp_brave_search

# --- App Config ---
LOG_LEVEL=INFO
TRACE_DIR=./data/traces
WORKSPACE_DIR=./workspace
