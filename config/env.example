# Copy to .env and fill in values

# --- Local Gemma 4 Model ---
# If unset, provider will auto-scan known roots like:
# - /mnt/raid1/CHK/playground/Gemma4/ckpts
# - /workspace/playground/Gemma4/ckpts
GEMMA_MODEL_PATH=/mnt/raid1/CHK/playground/Gemma4/ckpts/gemma-4-26B-A4B-it

# --- API Keys (optional) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- MCP Servers ---
BRAVE_API_KEY=           # for mcp_brave_search

# --- App Config ---
LOG_LEVEL=INFO
TRACE_DIR=./data/traces
WORKSPACE_DIR=./workspace
